{
  "title": "\ud83d\udd0d Helperium \u2014 Monitoring Overview",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["helperium", "monitoring"],
  "timezone": "browser",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "panels": [
    {
      "title": "Data Service \u2014 Request Rate",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(data_requests_total[1m])",
          "legendFormat": "{{operation}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Data Service \u2014 Request Duration (p95)",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(data_request_duration_ms_bucket[5m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Data Service \u2014 Avg DB Query Duration",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(data_db_query_duration_ms_sum[1m]) / rate(data_db_query_duration_ms_count[1m])",
          "legendFormat": "avg ms",
          "refId": "A"
        }
      ]
    },
    {
      "title": "MCP Gateway \u2014 Tool Calls",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "rate(mcp_tool_calls_total[1m])",
          "legendFormat": "{{tool}} ({{tenant}})",
          "refId": "A"
        }
      ]
    },
    {
      "title": "MCP Gateway \u2014 Active SSE Sessions",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 8,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(mcp_sessions_active)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "MCP Gateway \u2014 Rate Limit Hits",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "rate(mcp_rate_limit_hits_total[1m])",
          "legendFormat": "{{tenant}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "API \u2014 LLM Calls",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "rate(llm_calls_total[1m])",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "API \u2014 LLM Duration (avg)",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 8,
        "y": 16
      },
      "targets": [
        {
          "expr": "rate(llm_duration_ms_sum[1m]) / rate(llm_duration_ms_count[1m])",
          "legendFormat": "avg ms",
          "refId": "A"
        }
      ]
    },
    {
      "title": "API \u2014 Token Usage Rate",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "rate(llm_token_usage_total[1m])",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "API \u2014 Abuse Blocks by Reason",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "expr": "rate(abuse_blocked_total[1m])",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "API \u2014 LLM Cost",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 8,
        "y": 24
      },
      "targets": [
        {
          "expr": "rate(llm_cost_total[1m])",
          "legendFormat": "USD/min",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Admin Dashboard \u2014 Requests",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 12,
        "y": 24
      },
      "targets": [
        {
          "expr": "rate(admin_requests_total[1m])",
          "legendFormat": "{{path}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "RAG \u2014 Documents",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 3,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "expr": "rag_documents_total",
          "legendFormat": "docs",
          "refId": "A"
        }
      ]
    },
    {
      "title": "RAG \u2014 ChromaDB Size",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 3,
        "x": 3,
        "y": 32
      },
      "targets": [
        {
          "expr": "rag_chroma_size_bytes / 1048576",
          "legendFormat": "MB",
          "refId": "A"
        }
      ],
      "unit": "short"
    },
    {
      "title": "RAG \u2014 Search Rate",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 5,
        "x": 6,
        "y": 32
      },
      "targets": [
        {
          "expr": "rate(rag_searches_total[1m])",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "RAG \u2014 Search p95 Duration",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 5,
        "x": 11,
        "y": 32
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_search_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p95 ms",
          "refId": "A"
        }
      ]
    },
    {
      "title": "RAG \u2014 Cache Hit Ratio",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 0,
        "y": 40
      },
      "targets": [
        {
          "expr": "rate(rag_cache_hits_total[5m]) / (rate(rag_cache_hits_total[5m]) + rate(rag_cache_misses_total[5m])) or on() 1",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ]
    },
    {
      "title": "RAG \u2014 Import Duration (avg)",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 4,
        "y": 40
      },
      "targets": [
        {
          "expr": "rate(rag_import_duration_ms_sum[1m]) / rate(rag_import_duration_ms_count[1m])",
          "legendFormat": "avg ms",
          "refId": "A"
        }
      ]
    }
  ]
}
