{
  "name": "@helperium/admin-dashboard",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bash build.sh",
    "typecheck": "tsc --noEmit",
    "dev": "npm run typecheck && npx esbuild src/index.ts --bundle --format=iife --target=es2018 --sourcemap --outfile=internal/server/static/dist/app.js --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "html-validate": "^11.5.6",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vitest": "^3.1.0"
  }
}
