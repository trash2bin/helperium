# =============================================================================
# Agent-Tutor — Environment Configuration
# =============================================================================
# Copy to .env and fill in:
#   cp .env.example .env
#
# Startup:
#   ./scripts/dev.sh start                        # Native (Mac)
#   docker compose up -d                           # Docker (Linux)
#   docker compose --profile prod up -d            # Docker + Caddy (HTTPS)
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
# Leave empty for SQLite (default, file: university.db).
# Set to PostgreSQL connection string to use PostgreSQL.
# For local PostgreSQL: docker compose up -d db
DATABASE_URL=
# SQLite path (only used when DATABASE_URL is empty)
# DB_PATH=./university.db

# Data-service config path (for PostgreSQL or custom setups)
# Default: auto (dev.sh uses config.example.json with SQLite)
# DS_CONFIG=specs/config.postgres.json

# Data-service server limits
# Приоритет: переменная окружения → config.json server.* → дефолт.
# DS_REQUEST_TIMEOUT=30       # таймаут запроса в секундах (default: 30)
# DS_BODY_LIMIT_MB=10         # макс. размер тела запроса в MB (default: 10)
# DS_MAX_CONCURRENT=100       # макс. одновременных запросов (default: 100)

# Seed generation (deterministic seed for reproducible data)
# Pass to agent-seedgen via --seed flag: uv run agent-seedgen --seed 42
# (not an env var — CLI argument only)


# ─────────────────────────────────────────────────────────────────────────────
# LLM Provider (at least one required)
# ─────────────────────────────────────────────────────────────────────────────

# Ollama (local or remote)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:0.5b

# Mistral API (alternative to Ollama; leave empty if not used)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral/mistral-small

# ── LLM Provider Fallback ────────────────────────────────────────────
# Любая {PREFIX}_API_KEY + {PREFIX}_MODEL пара в .env автоматом
# импортируется как провайдер в админку (см. интерфейс).
#
# Примеры:
#   MISTRAL_API_KEY + MISTRAL_MODEL     → провайдер "mistral"
#   OPENAI_API_KEY  + OPENAI_MODEL      → провайдер "openai"
#   ANTHROPIC_API_KEY + ANTHROPIC_MODEL → провайдер "anthropic"
#
# Управление через админку → LLM Provider Fallback → Добавить.
# Данные в .data/providers.json (файл не трогать вручную).
#

# ─────────────────────────────────────────────────────────────────────────────
# RAG Service (document search, embeddings, vector store)
# ─────────────────────────────────────────────────────────────────────────────

RAG_HOST=127.0.0.1
RAG_PORT=8082
# URL used by MCP and API to reach the RAG service
RAG_SERVICE_URL=http://127.0.0.1:8082
# HTTP timeout for RAG client requests (seconds)
RAG_HTTP_TIMEOUT=60.0

# Embedding model (HuggingFace ID or local path)
RAG_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAG_EMBEDDING_BATCH_SIZE=64
# Device: cpu, cuda, mps
RAG_DEVICE=cpu
# Only use local model files (prevents downloading every time)
RAG_LOCAL_FILES_ONLY=0

# ── RAG Embedding Provider ──
RAG_EMBEDDING_PROVIDER=local                # local | litellm
# For litellm (OpenAI-compatible APIs):
# RAG_EMBEDDING_MODEL=text-embedding-3-small
# RAG_EMBEDDING_API_KEY=sk-...
# RAG_EMBEDDING_API_BASE=https://api.openai.com/v1
# RAG_EMBEDDING_DIMENSIONS=1536

# ── RAG Cache ──
RAG_CACHE_ENABLED=1
RAG_CACHE_MAXSIZE=256
RAG_CACHE_TTL=300

# ── RAG Admin API ──
# ADMIN_API_TOKEN=secret-token

# Chunking strategy: semantic, recursive, sentence
RAG_CHUNKER_TYPE=semantic
RAG_CHUNK_SIZE=768
RAG_CHUNK_OVERLAP=160
RAG_PAGE_OVERLAP_TOKENS=50

# BM25 reranker (pure Python, dense + keyword search)
RAG_RERANKER_ENABLED=1
RAG_RERANKER_K1=1.5
RAG_RERANKER_B=0.75
RAG_RERANKER_DENSE_FACTOR=3

# Embedding prefixes (e5/bge: "query:" / "passage:", MiniLM: leave empty)
RAG_QUERY_PREFIX=
RAG_PASSAGE_PREFIX=

# ChromaDB vector store
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=documents

# Context assembly
RAG_CONTEXT_MAX_TOKENS=8000


# ─────────────────────────────────────────────────────────────────────────────
# MCP Server
# ─────────────────────────────────────────────────────────────────────────────

MCP_HOST=0.0.0.0
MCP_PORT=8083
# Full URL used by the API agent to reach MCP via HTTP transport
MCP_SERVICE_URL=http://127.0.0.1:8083/mcp
MCP_MAX_SESSIONS=1000
MCP_SESSION_IDLE_TIMEOUT=5m
MCP_SESSION_MAX_LIFETIME=30m
# Timeout for a single JSON-RPC request/response cycle in POST /mcp/message (seconds)
MCP_POST_HANDLER_TIMEOUT=25
# Read header timeout for HTTP server (seconds) — protects against slowloris
MCP_READ_HEADER_TIMEOUT=10
# Idle timeout for HTTP server (seconds) — max time for keep-alive connections
MCP_IDLE_TIMEOUT=120
# Data-service base URL (used by mcp-gateway httpclient to fetch manifests/call tools)
DATA_SERVICE_URL=http://127.0.0.1:8084
# HTTP timeout for data-service calls (seconds)
DATA_SERVICE_TIMEOUT=30


# ─────────────────────────────────────────────────────────────────────────────
# API Server (agent orchestrator)
# ─────────────────────────────────────────────────────────────────────────────

DEMO_API_HOST=127.0.0.1
DEMO_API_PORT=8081
DEMO_WEB_HOST=127.0.0.1
DEMO_WEB_PORT=8080
# HTTP client timeout for web proxy to downstream services (seconds)
WEB_PROXY_TIMEOUT=30.0

# Python executable for subprocess calls (defaults to sys.executable)
PYTHON_EXECUTABLE=python3

# Thinking mode (true=on, false=off). Recommended: false in production.
ENABLE_THINK=true
# Debug mode (enables additional logging)
# DEMO_DEBUG=true

# Agent parameters
AGENT_TEMPERATURE=0.5
# Maximum tool-call iterations per turn
AGENT_MAX_ITERATIONS=5
# Maximum tokens for reasoning (thinking mode)
AGENT_MAX_TOKENS_THINKING=4096
# Maximum empty reasoning rounds (thinking with no response)
AGENT_MAX_EMPTY_ROUNDS=3
# Maximum accumulated tokens per turn (context window guard, ~chars/3.5)
AGENT_MAX_TURN_TOKENS=8000

# Turn timeout (seconds). ~90 in production, ~600 in development.
DEMO_REQUEST_TIMEOUT=600
# How many dialogue turns to keep in session memory
DEMO_HISTORY_TURNS=8
# Maximum content length stored in history (characters)
DEMO_HISTORY_CONTENT_CHARS=6000

# Session storage (SQLite file for chat sessions)
# DEMO_SESSION_DB_PATH=./demo_sessions.sqlite

# Backlog (full interaction tracing in JSONL)
BACKLOG_DIR=./backlog
BACKLOG_RETENTION_DAYS=30


# ─────────────────────────────────────────────────────────────────────────────
# Admin Dashboard
# ─────────────────────────────────────────────────────────────────────────────

# Listen address for admin dashboard HTTP server
LISTEN_ADDR=:8085
# Base URLs for upstream services (used by admin-dashboard to proxy requests)
DATA_SERVICE_URL=http://127.0.0.1:8084
RAG_SERVICE_URL=http://127.0.0.1:8082
API_SERVICE_URL=http://127.0.0.1:8081

# ─────────────────────────────────────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────────────────────────────────────

# Bearer token for API access (required in production, optional in dev)
API_BEARER_TOKEN=
# CORS origin for the web service (explicit domain in production, * in dev)
WEB_ORIGIN=*
# Default tenant ID for web UI tenant selector fallback
DEFAULT_TENANT_ID=default
# Comma-separated list of tenant IDs to expose in web UI (override auto-discovery)
DEMO_TENANTS=

# Bearer token for data-service admin API (/admin/* endpoints) and admin-dashboard.
# If empty, admin endpoints return 401. Required in production for tenant CRUD,
# config hot-reload, and runtime tenant management. dev.sh прокидывает эту переменную в data-service.
# ⚠️ In production, set a strong, unique token - never use the default 'secret' value!
ADMIN_TOKEN=
# Multi-tenancy: X-Tenant-ID header for routing requests to specific tenant's data-service.
# If set, mcp-gateway/api/web pass this header on every upstream call (currently only data-service
# understands it; mcp-gateway multi-tenant support — pending phase 3.7+).
# X_TENANT_ID=default


# ─────────────────────────────────────────────────────────────────────────────
# Domain for Caddy (production profile only)
# ─────────────────────────────────────────────────────────────────────────────

DOMAIN=localhost


# ─────────────────────────────────────────────────────────────────────────────
# Anti-Abuse (дефолты для embed-виджета, безопасны для production)
# ─────────────────────────────────────────────────────────────────────────────

# Token bucket refill rate (requests/second)
ABUSE_RPS=1.0
# Token bucket burst capacity
ABUSE_BURST=5
# Maximum message length (chars)
ABUSE_MESSAGE_MAX_LENGTH=2000
# Minimum interval between messages (seconds)
ABUSE_MIN_INTERVAL=1.0
# Maximum messages per session
ABUSE_SESSION_BUDGET=50
# Repeated text detection threshold (times)
ABUSE_REPEATED_THRESHOLD=3


# ─────────────────────────────────────────────────────────────────────────────
# Logging (формат и у��овень для всех сервисов)
# ─────────────────────────────────────────────────────────────────────────────

# Log format: json (structured) or text (plain)
LOG_FORMAT=json
# Log level: debug, info, warn, error
LOG_LEVEL=info


# ───────────────────���─────────────────────────────────────────────────────────
# Monitoring (/metrics endpoints)
# ─────────────────────────────────────────────────────────────────────────────

# Все сервисы отдают Prometheus-метрики на /metrics по умолчанию.
# Для запуска стека мониторинга: docker compose --profile monitoring up -d
ENABLE_METRICS=true


# ─────────────────────────────────────────────────────────────────────────────
# Document Generation (agent-generate CLI)
# ─────────────────────────────────────────────────────────────────────────────

# Ollama endpoint for generation (full /api/generate URL)
DOCGEN_OLLAMA_URL=http://host.docker.internal:11434/api/generate
# Ollama host (default: http://127.0.0.1:11434, used by the generator internally)
# OLLAMA_HOST=http://127.0.0.1:11434
# Ollama model for generation
DOCGEN_MODEL=qwen2.5:0.5b
# Output directory for generated materials
DOCGEN_OUTPUT_DIR=/data/app/generated_materials



# ─────────────────────────────────────────────────────────────────────────────
# Guardrails — Prompt Injection Detection
# ─────────────────────────────────────────────────────────────────────────────

# Enable/disable input/output prompt injection guardrails
GUARDRAIL_ENABLED=true
# Action on match: block (reject message) or warn (log only)
GUARDRAIL_BLOCK_ON_MATCH=block
# Block toxicity in LLM output: true=block, false=log-only (default: false)
GUARDRAIL_BLOCK_TOXIC=false
# Optional JSON override of blocked patterns (overrides built-in defaults)
GUARDRAIL_BLOCK_PATTERNS=


# ─────────────────────────────────────────────────────────────────────────────
# Spending Limits — Per-tenant LLM Cost Control
# ─────────────────────────────────────────────────────────────────────────────

# Enable/disable per-tenant LLM spending limits (hard stop)
SPENDING_LIMIT_ENABLED=true
# Default monthly budget per tenant (USD). 0 = no limit
SPENDING_DEFAULT_BUDGET=50.0
# Budget period: daily | weekly | monthly
SPENDING_BUDGET_PERIOD=monthly


# ─────────────────────────────────────────────────────────────────────────────
# Misc / Internal
# ─────────────────────────────────────────────────────────────────────────────

# Disable HuggingFace telemetry (set by agent-ingest)
# HF_HUB_DISABLE_TELEMETRY=1
# Disable tokenizers parallelism (set by agent-ingest)
# TOKENIZERS_PARALLELISM=false
