{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-tutor/schemas/schedule-entry",
  "properties": {
    "id": {
      "type": "string",
      "description": "Уникальный идентификатор записи"
    },
    "group": {
      "properties": {
        "id": {
          "type": "string",
          "description": "Уникальный идентификатор группы"
        },
        "name": {
          "type": "string",
          "description": "Название группы. Пример: ИВТ-21"
        },
        "speciality": {
          "type": "string",
          "description": "Специальность группы"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "description": "Группа"
    },
    "day": {
      "type": "string",
      "description": "День недели: Понедельник"
    },
    "lessons": {
      "items": {
        "properties": {
          "discipline_id": {
            "type": "string",
            "description": "ID дисциплины"
          },
          "discipline_name": {
            "type": "string",
            "description": "Название дисциплины"
          },
          "teacher_name": {
            "type": "string",
            "description": "ФИО преподавателя"
          },
          "room": {
            "type": "integer",
            "description": "Номер аудитории"
          }
        },
        "additionalProperties": false,
        "type": "object"
      },
      "type": "array",
      "description": "Список занятий"
    }
  },
  "additionalProperties": false,
  "type": "object"
}
