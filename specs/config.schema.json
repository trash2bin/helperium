{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helperium.local/specs/config.schema.json",
  "title": "data-service config",
  "description": "\u041a\u043e\u043d\u0444\u0438\u0433 data-service \u0434\u043b\u044f generic B2B SaaS \u0440\u0435\u0436\u0438\u043c\u0430. \u041e\u043f\u0440\u0435\u0434\u0435\u043b\u044f\u0435\u0442: \u043a\u0430\u043a\u043e\u0439 driver, \u043a\u0430\u043a\u0438\u0435 \u0441\u0443\u0449\u043d\u043e\u0441\u0442\u0438 \u0438\u0437\u0432\u043b\u0435\u043a\u0430\u0435\u043c \u0438\u0437 \u0411\u0414 \u043a\u043b\u0438\u0435\u043d\u0442\u0430, \u043a\u0430\u043a\u0438\u0435 endpoint'\u044b \u043f\u0443\u0431\u043b\u0438\u043a\u0443\u0435\u043c, \u043a\u0430\u043a\u0438\u0435 MCP-\u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u044b \u0433\u0435\u043d\u0435\u0440\u0438\u0440\u0443\u0435\u043c.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "data_source"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "\u0412\u0435\u0440\u0441\u0438\u044f \u0441\u0445\u0435\u043c\u044b \u043a\u043e\u043d\u0444\u0438\u0433\u0430. \u041d\u0430 \u0434\u0430\u043d\u043d\u044b\u0439 \u043c\u043e\u043c\u0435\u043d\u0442 \u2014 \u0442\u043e\u043b\u044c\u043a\u043e 1."
    },
    "data_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "driver",
        "dsn"
      ],
      "description": "\u041f\u043e\u0434\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u0435 \u043a \u043a\u043b\u0438\u0435\u043d\u0442\u0441\u043a\u043e\u0439 \u0411\u0414. data-service \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u0432 read-only \u0440\u0435\u0436\u0438\u043c\u0435: \u043d\u0435 \u043c\u043e\u0434\u0438\u0444\u0438\u0446\u0438\u0440\u0443\u0435\u0442 DDL.",
      "properties": {
        "driver": {
          "type": "string",
          "enum": [
            "sqlite",
            "postgres"
          ],
          "description": "\u0414\u0440\u0430\u0439\u0432\u0435\u0440 \u0421\u0423\u0411\u0414. \u0410\u0434\u0430\u043f\u0442\u0435\u0440\u044b \u043f\u043e\u0434 \u0434\u0440\u0443\u0433\u0438\u0435 \u0421\u0423\u0411\u0414 \u2014 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0438\u0435 \u0444\u0430\u0437\u044b."
        },
        "dsn": {
          "type": "string",
          "minLength": 1,
          "description": "DSN (\u0441\u0442\u0440\u043e\u043a\u0430 \u043f\u043e\u0434\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u044f). \u041f\u043e\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442 \u0448\u0430\u0431\u043b\u043e\u043d\u044b ${ENV_VAR}, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043f\u043e\u0434\u0441\u0442\u0430\u0432\u043b\u044f\u044e\u0442\u0441\u044f \u0438\u0437 \u043e\u043a\u0440\u0443\u0436\u0435\u043d\u0438\u044f \u043f\u0440\u0438 \u0437\u0430\u0433\u0440\u0443\u0437\u043a\u0435.",
          "examples": [
            "university.db",
            "file:./data/university.db",
            "postgres://tutor:tutor@127.0.0.1:5432/helperium"
          ]
        },
        "pool_size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 10,
          "description": "\u041c\u0430\u043a\u0441\u0438\u043c\u0443\u043c \u043e\u0434\u043d\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u0445 \u0441\u043e\u0435\u0434\u0438\u043d\u0435\u043d\u0438\u0439 \u043a \u0411\u0414."
        },
        "read_only": {
          "type": "boolean",
          "default": true,
          "description": "\u0415\u0441\u043b\u0438 true \u2014 data-service \u0437\u0430\u043f\u0440\u0435\u0449\u0430\u0435\u0442 \u043b\u044e\u0431\u044b\u0435 \u043c\u0443\u0442\u0438\u0440\u0443\u044e\u0449\u0438\u0435 \u043e\u043f\u0435\u0440\u0430\u0446\u0438\u0438 (INSERT/UPDATE/DELETE/DDL)."
        },
        "readonly_dsn": {
          "type": "string",
          "description": "DSN \u0441 \u043f\u0440\u0430\u0432\u0430\u043c\u0438 \u0442\u043e\u043b\u044c\u043a\u043e \u043d\u0430 \u0447\u0442\u0435\u043d\u0438\u0435 \u0434\u043b\u044f AI-\u0430\u0433\u0435\u043d\u0442\u0430 (database-level). \u0414\u043b\u044f SQLite: \u0442\u043e\u0442 \u0436\u0435 \u0444\u0430\u0439\u043b \u0441 ?mode=ro \u0438\u043b\u0438 'file:path.db?mode=ro'. \u0414\u043b\u044f PostgreSQL: DSN \u043e\u0442 \u043e\u0442\u0434\u0435\u043b\u044c\u043d\u043e\u0433\u043e \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044f \u0441 \u043f\u0440\u0430\u0432\u0430\u043c\u0438 SELECT. \u0415\u0441\u043b\u0438 \u0437\u0430\u0434\u0430\u043d \u2014 data-service \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u0435\u0433\u043e \u043a\u0430\u043a \u0432\u0442\u043e\u0440\u043e\u0439 \u043a\u043e\u043d\u043d\u0435\u043a\u0442 \u0434\u043b\u044f \u0432\u0441\u0435\u0445 \u0437\u0430\u043f\u0440\u043e\u0441\u043e\u0432 \u0430\u0433\u0435\u043d\u0442\u0430. \u0415\u0441\u043b\u0438 \u043d\u0435 \u0437\u0430\u0434\u0430\u043d \u2014 \u0430\u0433\u0435\u043d\u0442 \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u0447\u0435\u0440\u0435\u0437 \u043e\u0441\u043d\u043e\u0432\u043d\u0443\u044e DSN (app-level read_only)."
        }
      }
    },
    "introspection": {
      "type": "object",
      "additionalProperties": false,
      "description": "\u041d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438 auto-discovery \u0441\u0445\u0435\u043c\u044b \u0411\u0414 \u043f\u0440\u0438 \u0441\u0442\u0430\u0440\u0442\u0435 (\u0444\u0430\u0437\u0430 3.2+).",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "\u0412\u043a\u043b\u044e\u0447\u0438\u0442\u044c \u0438\u043d\u0442\u0440\u043e\u0441\u043f\u0435\u043a\u0446\u0438\u044e \u0441\u0445\u0435\u043c\u044b \u0411\u0414 \u043f\u0440\u0438 \u0441\u0442\u0430\u0440\u0442\u0435."
        },
        "include_schemas": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Schemas/\u0431\u0430\u0437\u044b \u0434\u043b\u044f \u0438\u043d\u0442\u0440\u043e\u0441\u043f\u0435\u043a\u0446\u0438\u0438 (Postgres only). \u041f\u043e \u0443\u043c\u043e\u043b\u0447\u0430\u043d\u0438\u044e \u2014 ['public']."
        },
        "exclude_tables": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "\u0420\u0435\u0433\u0443\u043b\u044f\u0440\u043d\u044b\u0435 \u0432\u044b\u0440\u0430\u0436\u0435\u043d\u0438\u044f \u0434\u043b\u044f \u0438\u043c\u0451\u043d \u0442\u0430\u0431\u043b\u0438\u0446, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043d\u0443\u0436\u043d\u043e \u0438\u0441\u043a\u043b\u044e\u0447\u0438\u0442\u044c. \u041d\u0430\u043f\u0440\u0438\u043c\u0435\u0440 ['^pg_', '^_'] \u2014 \u0441\u0438\u0441\u0442\u0435\u043c\u043d\u044b\u0435 \u0442\u0430\u0431\u043b\u0438\u0446\u044b Postgres."
        }
      }
    },
    "entities": {
      "type": "array",
      "description": "\u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435 \u0434\u043e\u043c\u0435\u043d\u043d\u044b\u0445 \u0441\u0443\u0449\u043d\u043e\u0441\u0442\u0435\u0439 \u043a\u043b\u0438\u0435\u043d\u0442\u0430. \u041a\u0430\u0436\u0434\u0430\u044f \u0441\u0443\u0449\u043d\u043e\u0441\u0442\u044c = \u0442\u0430\u0431\u043b\u0438\u0446\u0430 (\u0438\u043b\u0438 \u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043b\u0435\u043d\u0438\u0435) + \u043c\u0430\u043f\u043f\u0438\u043d\u0433 \u043f\u043e\u043b\u0435\u0439.",
      "items": {
        "$ref": "#/$defs/entity"
      }
    },
    "endpoints": {
      "type": "array",
      "description": "REST endpoints, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 data-service \u043f\u0443\u0431\u043b\u0438\u043a\u0443\u0435\u0442. \u041a\u0430\u0436\u0434\u044b\u0439 endpoint \u0441\u0441\u044b\u043b\u0430\u0435\u0442\u0441\u044f \u043d\u0430 entity, \u043e\u043f\u0435\u0440\u0430\u0446\u0438\u044e \u0438\u043b\u0438 custom query.",
      "items": {
        "$ref": "#/$defs/endpoint"
      }
    },
    "custom_queries": {
      "type": "object",
      "description": "Whitelist SQL-\u0437\u0430\u043f\u0440\u043e\u0441\u043e\u0432 \u0434\u043b\u044f endpoint'\u043e\u0432 \u0441 op=custom_query. \u0422\u043e\u043b\u044c\u043a\u043e SELECT, \u043e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u0435\u043d max_rows.",
      "additionalProperties": {
        "$ref": "#/$defs/custom_query"
      }
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "description": "\u041a\u043e\u043d\u0444\u0438\u0433\u0443\u0440\u0430\u0446\u0438\u044f endpoint'\u0430 /stats.",
      "properties": {
        "counters": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "entity"
            ],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_]*$",
                "description": "\u0418\u043c\u044f \u0441\u0447\u0451\u0442\u0447\u0438\u043a\u0430 \u0432 \u043e\u0442\u0432\u0435\u0442\u0435 /stats."
              },
              "entity": {
                "type": "string",
                "description": "\u0418\u043c\u044f entity \u0438\u0437 entities[]."
              },
              "filter": {
                "type": "string",
                "description": "\u041e\u043f\u0446\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u044b\u0439 WHERE \u0434\u043b\u044f \u043f\u043e\u0434\u0441\u0447\u0451\u0442\u0430 (\u043d\u0430\u043f\u0440\u0438\u043c\u0435\u0440: \"status = 'active'\")."
              }
            }
          }
        }
      }
    },
    "mcp_tools": {
      "type": "array",
      "description": "\u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435 MCP-\u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u043e\u0432 \u0434\u043b\u044f \u0433\u0435\u043d\u0435\u0440\u0430\u0446\u0438\u0438 mcp-gateway (Go, \u0444\u0430\u0437\u0430 3.4). \u041a\u0430\u0436\u0434\u044b\u0439 tool \u0441\u0441\u044b\u043b\u0430\u0435\u0442\u0441\u044f \u043d\u0430 endpoint.",
      "items": {
        "$ref": "#/$defs/mcp_tool"
      }
    },
    "approved_tools": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "\u0421\u043f\u0438\u0441\u043e\u043a \u043f\u0443\u0442\u0435\u0439 write-\u044d\u043d\u0434\u043f\u043e\u0438\u043d\u0442\u043e\u0432, \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0451\u043d\u043d\u044b\u0445 \u0434\u043b\u044f \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u044f \u0432 read-only \u0440\u0435\u0436\u0438\u043c\u0435. \u041a\u0430\u0436\u0434\u044b\u0439 \u044d\u043b\u0435\u043c\u0435\u043d\u0442 \u2014 path \u0438\u0437 endpoints[]. \u0415\u0441\u043b\u0438 \u043f\u0443\u0441\u0442\u043e\u0439 \u2014 write-\u0434\u043e\u0441\u0442\u0443\u043f \u0437\u0430\u043f\u0440\u0435\u0449\u0451\u043d \u0434\u043b\u044f \u0432\u0441\u0435\u0445 \u044d\u043d\u0434\u043f\u043e\u0438\u043d\u0442\u043e\u0432."
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "description": "Multi-tenancy \u0438 row-level isolation (\u0444\u0430\u0437\u0430 3.7).",
      "properties": {
        "strategy": {
          "type": "string",
          "enum": [
            "none",
            "header"
          ],
          "default": "none",
          "description": "\u0421\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u044f \u0438\u0437\u043e\u043b\u044f\u0446\u0438\u0438 \u0442\u0435\u043d\u0430\u043d\u0442\u043e\u0432. 'none' \u2014 \u043e\u0434\u0438\u043d \u0442\u0435\u043d\u0430\u043d\u0442, 'header' \u2014 X-Tenant-ID."
        },
        "tenant_header": {
          "type": "string",
          "default": "X-Tenant-ID",
          "description": "\u0418\u043c\u044f \u0437\u0430\u0433\u043e\u043b\u043e\u0432\u043a\u0430 \u0434\u043b\u044f \u043f\u0435\u0440\u0435\u0434\u0430\u0447\u0438 tenant_id."
        },
        "row_filters": {
          "type": "array",
          "description": "\u0414\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0435 WHERE-\u0443\u0441\u043b\u043e\u0432\u0438\u044f, \u043f\u0440\u0438\u043c\u0435\u043d\u044f\u0435\u043c\u044b\u0435 \u043a \u0437\u0430\u043f\u0440\u043e\u0441\u0430\u043c (multi-tenant isolation).",
          "items": {
            "$ref": "#/$defs/row_filter"
          }
        }
      }
    }
  },
  "$defs": {
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "table",
        "id_column",
        "fields"
      ],
      "description": "\u0414\u043e\u043c\u0435\u043d\u043d\u0430\u044f \u0441\u0443\u0449\u043d\u043e\u0441\u0442\u044c = \u043e\u0434\u043d\u0430 \u0442\u0430\u0431\u043b\u0438\u0446\u0430 \u0432 \u043a\u043b\u0438\u0435\u043d\u0442\u0441\u043a\u043e\u0439 \u0411\u0414.",
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "\u041f\u0443\u0431\u043b\u0438\u0447\u043d\u043e\u0435 \u0438\u043c\u044f \u0441\u0443\u0449\u043d\u043e\u0441\u0442\u0438 \u0432 API (lowercase snake_case)."
        },
        "table": {
          "type": "string",
          "minLength": 1,
          "description": "\u0418\u043c\u044f \u0442\u0430\u0431\u043b\u0438\u0446\u044b \u0432 \u0411\u0414. \u041c\u043e\u0436\u0435\u0442 \u0441\u043e\u0432\u043f\u0430\u0434\u0430\u0442\u044c \u0441 name, \u043d\u043e \u043d\u0435 \u043e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u043e."
        },
        "id_column": {
          "type": "string",
          "minLength": 1,
          "description": "\u0418\u043c\u044f \u043a\u043e\u043b\u043e\u043d\u043a\u0438 \u0441 \u043f\u0435\u0440\u0432\u0438\u0447\u043d\u044b\u043c \u043a\u043b\u044e\u0447\u043e\u043c."
        },
        "description": {
          "type": "string",
          "description": "\u0427\u0435\u043b\u043e\u0432\u0435\u043a\u043e\u0447\u0438\u0442\u0430\u0435\u043c\u043e\u0435 \u043e\u043f\u0438\u0441\u0430\u043d\u0438\u0435 \u0441\u0443\u0449\u043d\u043e\u0441\u0442\u0438 (\u0434\u043b\u044f OpenAPI \u0438 UI)."
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "description": "\u041c\u0430\u043f\u043f\u0438\u043d\u0433 \u043f\u0443\u0431\u043b\u0438\u0447\u043d\u044b\u0445 \u043f\u043e\u043b\u0435\u0439 \u043d\u0430 \u043a\u043e\u043b\u043e\u043d\u043a\u0438 \u0411\u0414.",
          "items": {
            "$ref": "#/$defs/entity_field"
          }
        },
        "relations": {
          "type": "array",
          "description": "\u0421\u0432\u044f\u0437\u0438 \u0441 \u0434\u0440\u0443\u0433\u0438\u043c\u0438 \u0441\u0443\u0449\u043d\u043e\u0441\u0442\u044f\u043c\u0438 (\u0434\u043b\u044f \u0434\u043e\u043a\u0443\u043c\u0435\u043d\u0442\u0430\u0446\u0438\u0438 \u0438 \u0432\u0430\u043b\u0438\u0434\u0430\u0446\u0438\u0438; JOIN \u0430\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438 \u041d\u0415 \u0441\u0442\u0440\u043e\u0438\u0442\u0441\u044f).",
          "items": {
            "$ref": "#/$defs/relation"
          }
        }
      }
    },
    "entity_field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "column",
        "type"
      ],
      "description": "\u041f\u043e\u043b\u0435 \u0441\u0443\u0449\u043d\u043e\u0441\u0442\u0438. name \u2014 \u043f\u0443\u0431\u043b\u0438\u0447\u043d\u043e\u0435 \u0438\u043c\u044f (API), column \u2014 \u0438\u043c\u044f \u043a\u043e\u043b\u043e\u043d\u043a\u0438 \u0432 \u0411\u0414.",
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "\u041f\u0443\u0431\u043b\u0438\u0447\u043d\u043e\u0435 \u0438\u043c\u044f \u043f\u043e\u043b\u044f \u0432 API."
        },
        "column": {
          "type": "string",
          "minLength": 1,
          "description": "\u0418\u043c\u044f \u043a\u043e\u043b\u043e\u043d\u043a\u0438 \u0432 \u0442\u0430\u0431\u043b\u0438\u0446\u0435 \u0411\u0414."
        },
        "type": {
          "type": "string",
          "enum": [
            "string",
            "int",
            "float",
            "bool",
            "json",
            "datetime",
            "date"
          ],
          "description": "Generic-\u0442\u0438\u043f \u043f\u043e\u043b\u044f. \u0410\u0434\u0430\u043f\u0442\u0435\u0440 \u043f\u0440\u0438\u0432\u043e\u0434\u0438\u0442 \u043d\u0430\u0442\u0438\u0432\u043d\u044b\u0439 \u0442\u0438\u043f \u0411\u0414 \u043a \u044d\u0442\u043e\u043c\u0443."
        },
        "nullable": {
          "type": "boolean",
          "default": false,
          "description": "\u041c\u043e\u0436\u0435\u0442 \u043b\u0438 \u043f\u043e\u043b\u0435 \u0431\u044b\u0442\u044c NULL."
        },
        "primary_key": {
          "type": "boolean",
          "default": false,
          "description": "\u042f\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u043b\u0438 \u043a\u043e\u043b\u043e\u043d\u043a\u0430 \u043f\u0435\u0440\u0432\u0438\u0447\u043d\u044b\u043c \u043a\u043b\u044e\u0447\u043e\u043c (\u043e\u0431\u044b\u0447\u043d\u043e \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u044f\u0435\u0442\u0441\u044f \u0447\u0435\u0440\u0435\u0437 id_column)."
        },
        "description": {
          "type": "string",
          "description": "\u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435 \u043f\u043e\u043b\u044f \u0434\u043b\u044f OpenAPI/UI."
        }
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "kind",
        "table",
        "local_fk"
      ],
      "description": "\u0421\u0432\u044f\u0437\u044c \u043c\u0435\u0436\u0434\u0443 \u0441\u0443\u0449\u043d\u043e\u0441\u0442\u044f\u043c\u0438. JOIN \u043d\u0435 \u0441\u0442\u0440\u043e\u0438\u0442\u0441\u044f \u0430\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438 \u2014 \u0434\u043b\u044f JOIN \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0439\u0442\u0435 custom_queries.",
      "properties": {
        "field": {
          "type": "string",
          "description": "\u0418\u043c\u044f \u043f\u043e\u043b\u044f \u0432 \u043f\u0443\u0431\u043b\u0438\u0447\u043d\u043e\u0439 \u0441\u0445\u0435\u043c\u0435 (\u043d\u0430\u043f\u0440\u0438\u043c\u0435\u0440, 'group')."
        },
        "kind": {
          "type": "string",
          "enum": [
            "many_to_one",
            "one_to_many",
            "many_to_many"
          ],
          "description": "\u0422\u0438\u043f \u0441\u0432\u044f\u0437\u0438."
        },
        "table": {
          "type": "string",
          "description": "\u0418\u043c\u044f \u0441\u0432\u044f\u0437\u0430\u043d\u043d\u043e\u0439 \u0442\u0430\u0431\u043b\u0438\u0446\u044b \u0432 \u0411\u0414."
        },
        "local_fk": {
          "type": "string",
          "description": "\u0418\u043c\u044f FK-\u043a\u043e\u043b\u043e\u043d\u043a\u0438 \u0432 \u0442\u0435\u043a\u0443\u0449\u0435\u0439 \u0442\u0430\u0431\u043b\u0438\u0446\u0435."
        },
        "target_fk": {
          "type": "string",
          "description": "\u0418\u043c\u044f FK-\u043a\u043e\u043b\u043e\u043d\u043a\u0438 \u0432 \u0441\u0432\u044f\u0437\u0430\u043d\u043d\u043e\u0439 \u0442\u0430\u0431\u043b\u0438\u0446\u0435 (\u0434\u043b\u044f many_to_many)."
        }
      }
    },
    "endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "path",
        "op"
      ],
      "description": "REST endpoint. method+path \u2014 \u043f\u0443\u0431\u043b\u0438\u0447\u043d\u044b\u0439 \u043a\u043e\u043d\u0442\u0440\u0430\u043a\u0442, op \u2014 \u0440\u0435\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u044f.",
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "POST",
            "PUT",
            "PATCH",
            "DELETE"
          ],
          "description": "HTTP \u043c\u0435\u0442\u043e\u0434. \u041d\u0430 \u0434\u0430\u043d\u043d\u044b\u0439 \u043c\u043e\u043c\u0435\u043d\u0442 \u043f\u043e\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442\u0441\u044f \u0442\u043e\u043b\u044c\u043a\u043e GET (read-only)."
        },
        "path": {
          "type": "string",
          "pattern": "^/[a-zA-Z0-9_{}/-]*$",
          "description": "URL-\u043f\u0443\u0442\u044c. \u041f\u043e\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442 {param} \u0434\u043b\u044f path-\u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043e\u0432.",
          "examples": [
            "/students/{id}",
            "/students"
          ]
        },
        "op": {
          "type": "string",
          "enum": [
            "builtin_health",
            "builtin_stats",
            "get_by_id",
            "find",
            "list",
            "custom_query"
          ],
          "description": "\u0420\u0435\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u044f: builtin (\u0431\u0435\u0437 entity) \u0438\u043b\u0438 \u0441\u0441\u044b\u043b\u043a\u0430 \u043d\u0430 entity/query."
        },
        "entity": {
          "type": "string",
          "description": "\u0418\u043c\u044f entity \u0438\u0437 entities[]. \u041e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u043e \u0434\u043b\u044f op=get_by_id, find, list."
        },
        "search_field": {
          "type": "string",
          "description": "\u0418\u043c\u044f \u043f\u043e\u043b\u044f (\u0438\u0437 entity.fields[].name) \u0434\u043b\u044f \u043f\u043e\u0438\u0441\u043a\u0430. \u0418\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u0442\u0441\u044f op=find."
        },
        "query_param": {
          "type": "string",
          "description": "\u0418\u043c\u044f query-\u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u0430 \u0434\u043b\u044f \u043f\u0435\u0440\u0435\u0434\u0430\u0447\u0438 \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u044f \u043f\u043e\u0438\u0441\u043a\u0430. \u041f\u043e \u0443\u043c\u043e\u043b\u0447\u0430\u043d\u0438\u044e \u0441\u043e\u0432\u043f\u0430\u0434\u0430\u0435\u0442 \u0441 search_field."
        },
        "query_id": {
          "type": "string",
          "description": "\u041a\u043b\u044e\u0447 \u0438\u0437 custom_queries. \u041e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u043e \u0434\u043b\u044f op=custom_query."
        },
        "params": {
          "type": "array",
          "description": "\u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043e\u0432 endpoint'\u0430 (path/query/body). \u0414\u043b\u044f GET \u2014 query.",
          "items": {
            "$ref": "#/$defs/endpoint_param"
          }
        },
        "description": {
          "type": "string",
          "description": "\u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435 endpoint'\u0430 \u0434\u043b\u044f OpenAPI."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "op": {
                "const": "get_by_id"
              }
            }
          },
          "then": {
            "required": [
              "entity"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "op": {
                "const": "find"
              }
            }
          },
          "then": {
            "required": [
              "entity",
              "search_field"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "op": {
                "const": "list"
              }
            }
          },
          "then": {
            "required": [
              "entity"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "op": {
                "const": "custom_query"
              }
            }
          },
          "then": {
            "required": [
              "query_id"
            ]
          }
        }
      ]
    },
    "endpoint_param": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "in"
      ],
      "description": "\u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440 endpoint'\u0430.",
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
          "description": "\u0418\u043c\u044f \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u0430."
        },
        "in": {
          "type": "string",
          "enum": [
            "path",
            "query",
            "body"
          ],
          "description": "\u0420\u0430\u0441\u043f\u043e\u043b\u043e\u0436\u0435\u043d\u0438\u0435 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u0430."
        },
        "type": {
          "type": "string",
          "enum": [
            "string",
            "int",
            "float",
            "bool"
          ],
          "default": "string",
          "description": "\u0422\u0438\u043f \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u0430."
        },
        "required": {
          "type": "boolean",
          "default": false,
          "description": "\u041e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u0439 \u043b\u0438 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440."
        },
        "description": {
          "type": "string",
          "description": "\u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435 \u0434\u043b\u044f OpenAPI."
        }
      }
    },
    "custom_query": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sql",
        "result_mapping",
        "max_rows"
      ],
      "description": "Whitelist SQL-\u0437\u0430\u043f\u0440\u043e\u0441. \u0422\u043e\u043b\u044c\u043a\u043e SELECT, \u043e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u0435\u043d max_rows, \u0432\u0441\u0435 user-input \u0447\u0435\u0440\u0435\u0437 '?' placeholder'\u044b.",
      "properties": {
        "sql": {
          "type": "string",
          "minLength": 1,
          "pattern": "^\\s*SELECT\\b",
          "description": "SQL-\u0437\u0430\u043f\u0440\u043e\u0441. \u0414\u043e\u043b\u0436\u0435\u043d \u043d\u0430\u0447\u0438\u043d\u0430\u0442\u044c\u0441\u044f \u0441 SELECT. \u0417\u0430\u043f\u0440\u0435\u0449\u0435\u043d\u044b ';', DDL, \u043c\u0443\u043b\u044c\u0442\u0438-statement."
        },
        "params": {
          "type": "array",
          "description": "\u0418\u043c\u0435\u043d\u0430 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043e\u0432 \u0432 \u043f\u043e\u0440\u044f\u0434\u043a\u0435 placeholder'\u043e\u0432 '?' \u0432 SQL.",
          "items": {
            "type": "string"
          }
        },
        "result_mapping": {
          "type": "object",
          "description": "\u041c\u0430\u043f\u043f\u0438\u043d\u0433 \u043a\u043e\u043b\u043e\u043d\u043e\u043a \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0430 \u043d\u0430 \u0442\u0438\u043f\u044b \u0434\u043b\u044f JSON Schema.",
          "additionalProperties": {
            "type": "object",
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "$ref": "#/$defs/entity_field/properties/type"
              },
              "nullable": {
                "type": "boolean",
                "default": false
              }
            }
          }
        },
        "max_rows": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000,
          "description": "\u041c\u0430\u043a\u0441\u0438\u043c\u0443\u043c \u0441\u0442\u0440\u043e\u043a \u0432 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0435. Hard limit, \u0437\u0430\u0449\u0438\u0442\u0430 \u043e\u0442 over-fetch."
        },
        "description": {
          "type": "string",
          "description": "\u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435 \u0437\u0430\u043f\u0440\u043e\u0441\u0430 \u0434\u043b\u044f OpenAPI."
        }
      }
    },
    "mcp_tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "endpoint",
        "description"
      ],
      "description": "MCP-\u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442, \u0433\u0435\u043d\u0435\u0440\u0438\u0440\u0443\u0435\u043c\u044b\u0439 mcp-gateway. \u0414\u0435\u043b\u0435\u0433\u0438\u0440\u0443\u0435\u0442 \u0432\u044b\u0437\u043e\u0432 \u043a endpoint'\u0443 data-service.",
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "\u0418\u043c\u044f \u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u0430 (\u0432\u044b\u0437\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u0430\u0433\u0435\u043d\u0442\u043e\u043c)."
        },
        "endpoint": {
          "type": "string",
          "description": "\u041f\u0443\u0442\u044c endpoint'\u0430 \u0438\u0437 endpoints[] (\u043d\u0430\u043f\u0440\u0438\u043c\u0435\u0440, '/students/{id}'). Path-\u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u044b \u0432 {id}."
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "\u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435 \u0434\u043b\u044f \u0430\u0433\u0435\u043d\u0442\u0430 (model-facing). \u041d\u0430 \u0440\u0443\u0441\u0441\u043a\u043e\u043c \u0438\u043b\u0438 \u0430\u043d\u0433\u043b\u0438\u0439\u0441\u043a\u043e\u043c \u2014 \u043d\u0430 \u0443\u0441\u043c\u043e\u0442\u0440\u0435\u043d\u0438\u0435 \u043a\u043b\u0438\u0435\u043d\u0442\u0430."
        },
        "params": {
          "type": "array",
          "description": "\u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043e\u0432 \u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u0430 (model-facing).",
          "items": {
            "$ref": "#/$defs/mcp_param"
          }
        }
      }
    },
    "mcp_param": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "description": "\u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440 MCP-\u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u0430 (model-facing, \u0431\u0435\u0437 \u043f\u0440\u0438\u0432\u044f\u0437\u043a\u0438 \u043a HTTP).",
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
          "description": "\u0418\u043c\u044f \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u0430."
        },
        "type": {
          "type": "string",
          "enum": [
            "string",
            "int",
            "float",
            "bool"
          ],
          "default": "string",
          "description": "\u0422\u0438\u043f \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u0430."
        },
        "required": {
          "type": "boolean",
          "default": false,
          "description": "\u041e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u0439 \u043b\u0438 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440."
        },
        "description": {
          "type": "string",
          "description": "\u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435 \u0434\u043b\u044f \u0430\u0433\u0435\u043d\u0442\u0430."
        }
      }
    },
    "row_filter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entity",
        "where"
      ],
      "description": "\u0414\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0439 WHERE \u0434\u043b\u044f multi-tenant isolation.",
      "properties": {
        "entity": {
          "type": "string",
          "description": "\u0418\u043c\u044f entity."
        },
        "where": {
          "type": "string",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_\\s=<>!\\.\\:\\(\\)\\'\\,]*$",
          "description": "WHERE-\u0432\u044b\u0440\u0430\u0436\u0435\u043d\u0438\u0435. \u041f\u043e\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442 placeholder :tenant_id (\u043f\u043e\u0434\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u0438\u0437 \u0437\u0430\u0433\u043e\u043b\u043e\u0432\u043a\u0430)."
        }
      }
    }
  }
}
