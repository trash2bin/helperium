{
  "version": 1,
  "data_source": {
    "driver": "postgres",
    "dsn": "${DATABASE_URL:-postgresql://tutor:tutor@127.0.0.1:5432/agent_tutor?sslmode=disable}",
    "pool_size": 10,
    "read_only": true,
    "readonly_dsn": "postgres://readonly:readonly@127.0.0.1:5432/agent_tutor?sslmode=disable"
  },
  "introspection": {
    "enabled": false,
    "exclude_tables": []
  },
  "entities": [
    {
      "name": "group",
      "table": "groups",
      "id_column": "id",
      "description": "Учебная группа",
      "fields": [
        {
          "name": "id",
          "column": "id",
          "type": "string",
          "nullable": false,
          "primary_key": true
        },
        {
          "name": "name",
          "column": "name",
          "type": "string",
          "nullable": false,
          "description": "Название группы. Пример: ИВТ-21"
        },
        {
          "name": "speciality",
          "column": "speciality",
          "type": "string",
          "nullable": false,
          "description": "Специальность группы"
        }
      ]
    },
    {
      "name": "student",
      "table": "students",
      "id_column": "id",
      "description": "Карточка студента",
      "fields": [
        {
          "name": "id",
          "column": "id",
          "type": "string",
          "nullable": false,
          "primary_key": true
        },
        {
          "name": "full_name",
          "column": "name",
          "type": "string",
          "nullable": false,
          "description": "Полное ФИО студента"
        },
        {
          "name": "course",
          "column": "course",
          "type": "int",
          "nullable": true,
          "description": "Курс обучения (1-6)"
        }
      ],
      "relations": [
        {
          "field": "group",
          "kind": "many_to_one",
          "table": "groups",
          "local_fk": "group_id"
        }
      ]
    },
    {
      "name": "teacher",
      "table": "teachers",
      "id_column": "id",
      "description": "Преподаватель",
      "fields": [
        {
          "name": "id",
          "column": "id",
          "type": "string",
          "nullable": false,
          "primary_key": true
        },
        {
          "name": "full_name",
          "column": "name",
          "type": "string",
          "nullable": false,
          "description": "Полное ФИО преподавателя"
        },
        {
          "name": "disciplines",
          "column": "disciplines_json",
          "type": "json",
          "nullable": false,
          "description": "Список названий дисциплин"
        }
      ]
    },
    {
      "name": "discipline",
      "table": "disciplines",
      "id_column": "id",
      "description": "Учебная дисциплина",
      "fields": [
        {
          "name": "id",
          "column": "id",
          "type": "string",
          "nullable": false,
          "primary_key": true
        },
        {
          "name": "name",
          "column": "name",
          "type": "string",
          "nullable": false,
          "description": "Название дисциплины"
        },
        {
          "name": "description",
          "column": "description",
          "type": "string",
          "nullable": false,
          "description": "Краткое описание"
        }
      ]
    },
    {
      "name": "grade",
      "table": "grades",
      "id_column": "id",
      "description": "Оценка студента",
      "fields": [
        {
          "name": "id",
          "column": "id",
          "type": "string",
          "nullable": false,
          "primary_key": true
        },
        {
          "name": "student_id",
          "column": "student_id",
          "type": "string",
          "nullable": false
        },
        {
          "name": "student_name",
          "column": "_computed",
          "type": "string",
          "nullable": true,
          "description": "Имя студента (подтягивается через JOIN)"
        },
        {
          "name": "discipline_id",
          "column": "discipline_id",
          "type": "string",
          "nullable": false
        },
        {
          "name": "discipline_name",
          "column": "_computed",
          "type": "string",
          "nullable": true,
          "description": "Название дисциплины (JOIN)"
        },
        {
          "name": "grade",
          "column": "grade",
          "type": "string",
          "nullable": false,
          "description": "Значение оценки: 5, 4, 3, 2, зачёт, незачёт"
        },
        {
          "name": "date",
          "column": "date",
          "type": "date",
          "nullable": false,
          "description": "Дата в формате YYYY-MM-DD"
        }
      ]
    },
    {
      "name": "schedule",
      "table": "schedule",
      "id_column": "id",
      "description": "Запись расписания на один день",
      "fields": [
        {
          "name": "id",
          "column": "id",
          "type": "string",
          "nullable": false,
          "primary_key": true
        },
        {
          "name": "day",
          "column": "day",
          "type": "string",
          "nullable": false,
          "description": "День недели"
        },
        {
          "name": "group_id",
          "column": "group_id",
          "type": "string",
          "nullable": false
        },
        {
          "name": "lessons",
          "column": "lessons_json",
          "type": "json",
          "nullable": false,
          "description": "Список занятий (teacher, discipline, room)"
        }
      ],
      "relations": [
        {
          "field": "group",
          "kind": "many_to_one",
          "table": "groups",
          "local_fk": "group_id"
        }
      ]
    }
  ],
  "endpoints": [
    {
      "method": "GET",
      "path": "/health",
      "op": "builtin_health",
      "description": "Проверка состояния сервиса и БД"
    },
    {
      "method": "GET",
      "path": "/stats",
      "op": "builtin_stats",
      "description": "Счётчики записей по сущностям"
    },
    {
      "method": "GET",
      "path": "/students/{id}",
      "op": "get_by_id",
      "entity": "student",
      "description": "Карточка студента по ID"
    },
    {
      "method": "GET",
      "path": "/students",
      "op": "find",
      "entity": "student",
      "search_field": "full_name",
      "query_param": "name",
      "description": "Поиск студента по ФИО (без name — список всех)"
    },
    {
      "method": "GET",
      "path": "/students/{id}/disciplines",
      "op": "custom_query",
      "query_id": "student_disciplines",
      "description": "Список дисциплин студента (через группу → расписание)",
      "params": [
        {
          "name": "id",
          "in": "path",
          "type": "string",
          "required": true,
          "description": "ID студента"
        }
      ]
    },
    {
      "method": "GET",
      "path": "/students/{id}/grades",
      "op": "custom_query",
      "query_id": "student_grades",
      "description": "Оценки студента, опционально по дисциплине",
      "params": [
        {
          "name": "id",
          "in": "path",
          "type": "string",
          "required": true,
          "description": "ID студента"
        }
      ]
    },
    {
      "method": "GET",
      "path": "/teachers",
      "op": "find",
      "entity": "teacher",
      "search_field": "full_name",
      "query_param": "name",
      "description": "Поиск преподавателя по ФИО"
    },
    {
      "method": "GET",
      "path": "/teachers/{name}/schedule",
      "op": "custom_query",
      "query_id": "teacher_schedule",
      "description": "Расписание преподавателя, опционально по дню"
    },
    {
      "method": "GET",
      "path": "/groups/{id}/schedule",
      "op": "custom_query",
      "query_id": "group_schedule",
      "description": "Расписание группы, опционально по дню",
      "params": [
        {
          "name": "id",
          "in": "path",
          "type": "string",
          "required": true,
          "description": "ID группы"
        }
      ]
    },
    {
      "method": "GET",
      "path": "/schedule",
      "op": "custom_query",
      "query_id": "all_schedule",
      "description": "Всё расписание (для demo overview)"
    },
    {
      "method": "GET",
      "path": "/grades",
      "op": "custom_query",
      "query_id": "all_grades",
      "description": "Все оценки с именами студентов (для demo overview)"
    },
    {
      "method": "GET",
      "path": "/disciplines",
      "op": "list",
      "entity": "discipline",
      "description": "Все дисциплины"
    }
  ],
  "custom_queries": {
    "student_disciplines": {
      "sql": "SELECT d.id, d.name, d.description FROM disciplines d WHERE d.id IN (SELECT DISTINCT elem->>'discipline_id' FROM schedule s, jsonb_array_elements(s.lessons_json::jsonb) elem WHERE s.group_id = (SELECT group_id FROM students WHERE id = ?) AND elem->>'discipline_id' IS NOT NULL)",
      "params": [
        "id"
      ],
      "result_mapping": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "max_rows": 100,
      "description": "Дисциплины студента через его группу"
    },
    "student_grades": {
      "sql": "SELECT g.id, g.student_id, g.discipline_id, COALESCE(d.name, 'Неизвестная дисциплина') AS discipline_name, g.grade, g.date FROM grades g LEFT JOIN disciplines d ON d.id = g.discipline_id WHERE g.student_id = ? ORDER BY g.date DESC, d.name ASC",
      "params": [
        "id"
      ],
      "result_mapping": {
        "id": {
          "type": "string"
        },
        "student_id": {
          "type": "string"
        },
        "discipline_id": {
          "type": "string"
        },
        "discipline_name": {
          "type": "string",
          "nullable": true
        },
        "grade": {
          "type": "string"
        },
        "date": {
          "type": "date"
        }
      },
      "max_rows": 500,
      "description": "Оценки студента"
    },
    "teacher_schedule": {
      "sql": "SELECT s.id, s.day, s.group_id, g.name AS group_name, g.speciality, s.lessons_json AS lessons FROM schedule s LEFT JOIN groups g ON g.id = s.group_id",
      "params": [],
      "result_mapping": {
        "id": {
          "type": "string"
        },
        "day": {
          "type": "string"
        },
        "group_id": {
          "type": "string",
          "nullable": true
        },
        "group_name": {
          "type": "string",
          "nullable": true
        },
        "speciality": {
          "type": "string",
          "nullable": true
        },
        "lessons": {
          "type": "json",
          "description": "JSON-массив занятий"
        }
      },
      "max_rows": 1000,
      "description": "Расписание преподавателя (фильтрация по teacher_name и day — на уровне Go)"
    },
    "group_schedule": {
      "sql": "SELECT s.id, s.day, s.group_id, g.name AS group_name, g.speciality, s.lessons_json AS lessons FROM schedule s LEFT JOIN groups g ON g.id = s.group_id WHERE s.group_id = ?",
      "params": [
        "id"
      ],
      "result_mapping": {
        "id": {
          "type": "string"
        },
        "day": {
          "type": "string"
        },
        "group_id": {
          "type": "string"
        },
        "group_name": {
          "type": "string",
          "nullable": true
        },
        "speciality": {
          "type": "string",
          "nullable": true
        },
        "lessons": {
          "type": "json"
        }
      },
      "max_rows": 1000,
      "description": "Расписание группы"
    },
    "all_schedule": {
      "sql": "SELECT s.id, s.day, s.group_id, g.name AS group_name, g.speciality, s.lessons_json AS lessons FROM schedule s LEFT JOIN groups g ON g.id = s.group_id ORDER BY g.name, s.day",
      "params": [],
      "result_mapping": {
        "id": {
          "type": "string"
        },
        "day": {
          "type": "string"
        },
        "group_id": {
          "type": "string",
          "nullable": true
        },
        "group_name": {
          "type": "string",
          "nullable": true
        },
        "speciality": {
          "type": "string",
          "nullable": true
        },
        "lessons": {
          "type": "json"
        }
      },
      "max_rows": 5000,
      "description": "Всё расписание"
    },
    "all_grades": {
      "sql": "SELECT g.id, g.student_id, COALESCE(s.name, 'Неизвестный студент') AS student_name, g.discipline_id, COALESCE(d.name, 'Неизвестная дисциплина') AS discipline_name, g.grade, g.date FROM grades g LEFT JOIN students s ON s.id = g.student_id LEFT JOIN disciplines d ON d.id = g.discipline_id ORDER BY g.date DESC LIMIT 80",
      "params": [],
      "result_mapping": {
        "id": {
          "type": "string"
        },
        "student_id": {
          "type": "string"
        },
        "student_name": {
          "type": "string",
          "nullable": true
        },
        "discipline_id": {
          "type": "string"
        },
        "discipline_name": {
          "type": "string",
          "nullable": true
        },
        "grade": {
          "type": "string"
        },
        "date": {
          "type": "date"
        }
      },
      "max_rows": 80,
      "description": "Последние 80 оценок"
    }
  },
  "stats": {
    "counters": [
      {
        "name": "students",
        "entity": "student"
      },
      {
        "name": "teachers",
        "entity": "teacher"
      },
      {
        "name": "disciplines",
        "entity": "discipline"
      },
      {
        "name": "grades",
        "entity": "grade"
      },
      {
        "name": "schedule",
        "entity": "schedule"
      }
    ]
  },
  "mcp_tools": [
    {
      "name": "find_student_by_name",
      "endpoint": "/students",
      "description": "Найти студента по полному ФИО. Пример: 'Иван Петров Иванович'.",
      "params": [
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "Полное ФИО студента"
        }
      ]
    },
    {
      "name": "get_student",
      "endpoint": "/students/{id}",
      "description": "Получить карточку студента по ID. Получи ID через find_student_by_name.",
      "params": [
        {
          "name": "id",
          "type": "string",
          "required": true,
          "description": "ID студента"
        }
      ]
    },
    {
      "name": "get_schedule",
      "endpoint": "/groups/{id}/schedule",
      "description": "Расписание группы студента на неделю или на конкретный день.",
      "params": [
        {
          "name": "id",
          "type": "string",
          "required": true,
          "description": "ID группы (из поля group.id студента)"
        },
        {
          "name": "day",
          "type": "string",
          "required": false,
          "description": "День недели по-русски. Без параметра — всё расписание"
        }
      ]
    },
    {
      "name": "get_disciplines",
      "endpoint": "/students/{id}/disciplines",
      "description": "Список дисциплин студента.",
      "params": [
        {
          "name": "id",
          "type": "string",
          "required": true,
          "description": "ID студента"
        }
      ]
    },
    {
      "name": "get_student_grades",
      "endpoint": "/students/{id}/grades",
      "description": "Оценки студента, опционально отфильтрованные по дисциплине.",
      "params": [
        {
          "name": "id",
          "type": "string",
          "required": true,
          "description": "ID студента"
        },
        {
          "name": "discipline_id",
          "type": "string",
          "required": false,
          "description": "ID дисциплины для фильтрации"
        }
      ]
    },
    {
      "name": "get_teacher_by_name",
      "endpoint": "/teachers",
      "description": "Найти преподавателя по полному ФИО.",
      "params": [
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "Полное ФИО преподавателя"
        }
      ]
    },
    {
      "name": "get_teacher_schedule",
      "endpoint": "/teachers/{name}/schedule",
      "description": "Расписание преподавателя, опционально по дню недели.",
      "params": [
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "Полное ФИО преподавателя"
        },
        {
          "name": "day",
          "type": "string",
          "required": false,
          "description": "День недели"
        }
      ]
    }
  ],
  "auth": {
    "strategy": "none",
    "row_filters": []
  }
}
