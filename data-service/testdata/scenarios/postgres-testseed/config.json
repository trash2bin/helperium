  "custom_queries": {
    "student_grades": {
      "sql": "SELECT g.id, g.student_id, g.discipline_id, COALESCE(d.name, 'Неизвестная дисциплина') AS discipline_name, g.grade, g.date FROM grades g LEFT JOIN disciplines d ON d.id = g.discipline_id WHERE g.student_id = ? ORDER BY g.date DESC, d.name ASC",
      "params": [
        "id"
      ],
      "result_mapping": {
        "id": {
          "type": "string"
        },
        "student_id": {
          "type": "string"
        },
        "discipline_id": {
          "type": "string"
        },
        "discipline_name": {
          "type": "string",
          "nullable": true
        },
        "grade": {
          "type": "string"
        },
        "date": {
          "type": "date"
        }
      },
      "max_rows": 500,
      "description": "Оценки студента"
    },
    "group_schedule": {
      "sql": "SELECT s.id, s.day, s.group_id, g.name AS group_name, g.speciality, s.lessons_json AS lessons FROM schedule s LEFT JOIN groups g ON g.id = s.group_id WHERE s.group_id = ?",
      "params": [
        "id"
      ],
      "result_mapping": {
        "id": {
          "type": "string"
        },
        "day": {
          "type": "string"
        },
        "group_id": {
          "type": "string"
        },
        "group_name": {
          "type": "string",
          "nullable": true
        },
        "speciality": {
          "type": "string",
          "nullable": true
        },
        "lessons": {
          "type": "json"
        }
      },
      "max_rows": 1000,
      "description": "Расписание группы"
    },
    "all_grades": {
      "sql": "SELECT g.id, g.student_id, COALESCE(s.name, 'Неизвестный студент') AS student_name, g.discipline_id, COALESCE(d.name, 'Неизвестная дисциплина') AS discipline_name, g.grade, g.date FROM grades g LEFT JOIN students s ON s.id = g.student_id LEFT JOIN disciplines d ON d.id = g.discipline_id ORDER BY g.date DESC LIMIT 80",
      "params": [],
      "result_mapping": {
        "id": {
          "type": "string"
        },
        "student_id": {
          "type": "string"
        },
        "student_name": {
          "type": "string",
          "nullable": true
        },
        "discipline_id": {
          "type": "string"
        },
        "discipline_name": {
          "type": "string",
          "nullable": true
        },
        "grade": {
          "type": "string"
        },
        "date": {
          "type": "date"
        }
      },
      "max_rows": 80,
      "description": "Последние 80 оценок"
    },
    "all_schedule": {
      "sql": "SELECT s.id, s.day, s.group_id, g.name AS group_name, g.speciality, s.lessons_json AS lessons FROM schedule s LEFT JOIN groups g ON g.id = s.group_id ORDER BY g.name, s.day",
      "params": [],
      "result_mapping": {
        "id": {
          "type": "string"
        },
        "day": {
          "type": "string"
        },
        "group_id": {
          "type": "string",
          "nullable": true
        },
        "group_name": {
          "type": "string",
          "nullable": true
        },
        "speciality": {
          "type": "string",
          "nullable": true
        },
        "lessons": {
          "type": "json"
        }
      },
      "max_rows": 5000,
      "description": "Всё расписание"
    },
    "student_disciplines": {
      "sql": "SELECT d.id, d.name, d.description FROM disciplines d WHERE d.id IN (SELECT DISTINCT elem->>'discipline_id' FROM schedule s, jsonb_array_elements(s.lessons_json::jsonb) elem WHERE s.group_id = (SELECT group_id FROM students WHERE id = ?) AND elem->>'discipline_id' IS NOT NULL)",
      "params": [
        "id"
      ],
      "result_mapping": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "max_rows": 100,
      "description": "Дисциплины студента через его группу"
    }
  },
