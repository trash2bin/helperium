      "op": "find",
      "entity": "student",
      "search_field": "full_name",
      "query_param": "name"
    },
    {
      "method": "GET",
      "path": "/students/{id}/grades",
      "op": "custom_query",
      "query_id": "student_grades",
      "params": [
